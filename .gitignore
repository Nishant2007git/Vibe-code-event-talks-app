# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkouts

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   For a working directory, you might not.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if lock is generated in Windows, it could fail on Mac/Linux.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be included in version control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be included in version control.
#.pdm-python.path
#.pdm-build/

# PIP Python virtual environments
.venv/
venv/
ENV/
env/
system_env/
virtualenv/

